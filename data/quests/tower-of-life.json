      "index": 0,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to Effigy at the Tower of Life near fairy ring code DJP.",
        "es": "Habla con Effigy en la Tower of Life, cerca del fairy ring código DJP."
      },
      "chatOptions": [
        "1 Sure, why not.",
        "Accept"
      ],
      "highlightTerms": [
        "Effigy",
        "Tower of Life"
      ]
    },
    {
