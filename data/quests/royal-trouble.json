  "steps": [
    {
      "index": 0,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Speak to Advisor Ghrim in Miscellania."
      },
      "chatOptions": [
        "2 Has anything been happening in the kingdom recently?",
        "Accept"
      ],
      "highlightTerms": [
        "Advisor Ghrim",
        "Miscellania"
      ]
    },
    {
      "index": 1,
      "indent": 1,
      "section": "Getting started",
      "text": {
        "en": "Fast access via Ring of Wealth (or higher tier luck enhancer rings, which offer unlimited teleports), fairy ring CIP, or the sailor near the larger boat north of the Rellekka market."
      },
      "chatOptions": [],
      "highlightTerms": [
        "Ring of Wealth",
        "fairy ring",
        "sailor"
      ]
    },
    {
      "index": 2,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Speak to either Prince Brand or Princess Astrid. Wait for the cutscene."
      },
      "chatOptions": [],
      "highlightTerms": [
        "Prince Brand",
        "Princess Astrid"
      ]
    },
    {
      "index": 3,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to King Vargas."
      },
      "chatOptions": [
        "1 Right away, Your Majesty"
      ],
      "highlightTerms": [
        "King Vargas"
      ]
    },
    {
      "index": 4,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to Gardener Gunnhild at the flax patch."
      },
      "chatOptions": [
        "1 Royal Trouble."
      ],
      "highlightTerms": [
        "Gardener Gunnhild"
      ]
    },
    {
      "index": 5,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Run east over to Etceteria and talk to Queen Sigrid."
      },
      "chatOptions": [
        "1 Of course, it's my duty."
      ],
      "highlightTerms": [
        "Etceteria",
        "Queen Sigrid"
      ]
    },
    {
      "index": 6,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to Matilda in the Etceteria castle courtyard."
      },
      "chatOptions": [],
      "highlightTerms": [
        "Matilda"
      ]
    },
    {
      "index": 7,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to Queen Sigrid again."
      },
      "chatOptions": [
        "2 I suppose so..."
      ]
    },
    {
      "index": 8,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to King Vargas."
      },
      "chatOptions": []
    },
    {
      "index": 9,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to Advisor Ghrim."
      },
      "chatOptions": [
        "1 King Vargas asked me to talk to you."
      ]
    },
    {
      "index": 10,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to the Sailor on the docks in Miscellania (caution to not travel to Rellekka)."
      },
      "chatOptions": [
        "2 I'm looking for a sailor..."
      ],
      "highlightTerms": [
        "Sailor"
      ]
    },
    {
      "index": 11,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to King Vargas again with at least 1 inventory space free."
      },
      "chatOptions": []
    },
    {
      "index": 12,
      "indent": 0,
      "section": "Miscellania dungeons",
      "text": {
        "en": "Gear up for the final fight now. Having 8 free inventory spaces is recommended."
      },
      "chatOptions": []
    },
    {
      "index": 13,
      "indent": 0,
      "section": "Miscellania dungeons",
      "text": {
        "en": "Go downstairs and enter the dungeon ladder within the southern portion of the Miscellania courtyard."
      },
      "chatOptions": [],
      "highlightTerms": [
        "Miscellania"
      ]
    },
    {
      "index": 14,
      "indent": 0,
      "section": "Miscellania dungeons",
      "text": {
        "en": "Go into the bar to the east, and speak with Donal."
      },
      "chatOptions": [
        "1 Of course. Dealing with monsters is what I do best!"
      ],
      "highlightTerms": [
        "Donal"
      ]
    },
    {
      "index": 15,
      "indent": 0,
      "section": "Miscellania dungeons",
      "text": {
        "en": "Head north to use the mining prop on the crevice, and go through."
      },
      "chatOptions": []
    },
    {
      "index": 16,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Pick up the engine, 3 pulley beams, 3 beams, and 2 rope from the crates."
      },
      "chatOptions": [],
      "highlightTerms": [
        "engine",
        "pulley beam",
        "beam",
        "rope"
      ]
    },
    {
      "index": 17,
      "indent": 1,
      "section": "Fixing the lift",
      "text": {
        "en": "There is a bug where sometimes you won't be able to pick up the engine. Leave the dungeon and come back, or try to use area loot."
      },
      "chatOptions": []
    },
    {
      "index": 18,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Add 5 coal to the engine (coal can be obtained by mining the rocks in the cavern)."
      },
      "chatOptions": [],
      "highlightTerms": [
        "coal"
      ]
    },
    {
      "index": 19,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Use a pulley beam on the broken scaffolding."
      },
      "chatOptions": []
    },
    {
      "index": 20,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Use a beam from your backpack on a pulley beam in your pack, and you'll get a long pulley beam."
      },
      "chatOptions": [],
      "highlightTerms": [
        "long pulley beam"
      ]
    },
    {
      "index": 21,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Attach another beam from your pack to get a longer pulley beam, use that on the scaffolding."
      },
      "chatOptions": [],
      "highlightTerms": [
        "longer pulley beam"
      ]
    },
    {
      "index": 22,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Use your last pulley beam on the scaffolding."
      },
      "chatOptions": []
    },
    {
      "index": 23,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Use your rope on the scaffolding."
      },
      "chatOptions": []
    },
    {
      "index": 24,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Use the third beam on the platform (north side)."
      },
      "chatOptions": []
    },
    {
      "index": 25,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Use the engine with coal in it on the engine platform (middle)."
      },
      "chatOptions": []
    },
    {
      "index": 26,
      "indent": 0,
      "section": "Fixing the lift",
      "text": {
        "en": "Once complete you can now use the lift."
      },
      "chatOptions": []
    },
    {
      "index": 27,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Pick up the plank off the ground, and enter the tunnel."
      },
      "chatOptions": []
    },
    {
      "index": 28,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Continue east."
      },
      "chatOptions": []
    },
    {
      "index": 29,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Use the rope in your inventory on the northern end of the rock and swing across the river."
      },
      "chatOptions": []
    },
    {
      "index": 30,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Search the fire remains to obtain a burnt diary."
      },
      "chatOptions": [],
      "highlightTerms": [
        "burnt diary"
      ]
    },
    {
      "index": 31,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Use the plank to cross the small rocks."
      },
      "chatOptions": []
    },
    {
      "index": 32,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Search the other fire remains (2 fires before vents) to add pages to the diary."
      },
      "chatOptions": []
    },
    {
      "index": 33,
      "indent": 1,
      "section": "Exploring the tunnel",
      "text": {
        "en": "The steam vents in this area will hurt you slightly. Surge across to avoid any damage."
      },
      "chatOptions": []
    },
    {
      "index": 34,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Make your way to the end of the tunnel, collecting the 2 remaining diary pages."
      },
      "chatOptions": []
    },
    {
      "index": 35,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Read the burnt diary."
      },
      "chatOptions": []
    },
    {
      "index": 36,
      "indent": 0,
      "section": "Exploring the tunnel",
      "text": {
        "en": "Squeeze through the crevice at the end."
      },
      "chatOptions": []
    },
    {
      "index": 37,
      "indent": 0,
      "section": "Final fight",
      "text": {
        "en": "After the cutscene, finish the dialogue with the teenagers."
      },
      "chatOptions": []
    },
    {
      "index": 38,
      "indent": 0,
      "section": "Final fight",
      "text": {
        "en": "Continue down the tunnel, squeeze through the crevice."
      },
      "chatOptions": []
    },
    {
      "index": 39,
      "indent": 0,
      "section": "Final fight",
      "text": {
        "en": "Kill the Giant Sea Snake, and pick up the heavy box."
      },
      "chatOptions": [],
      "highlightTerms": [
        "Giant Sea Snake",
        "heavy box"
      ]
    },
    {
      "index": 40,
      "indent": 0,
      "section": "Final fight",
      "text": {
        "en": "Go back through the crevice and a guard will drop a rope down to help you up."
      },
      "chatOptions": []
    },
    {
      "index": 41,
      "indent": 0,
      "section": "Final fight",
      "text": {
        "en": "Talk to Queen Sigrid with at least 1 free inventory space."
      },
      "chatOptions": []
    },
    {
      "index": 42,
      "indent": 1,
      "section": "Final fight",
      "text": {
        "en": "If you forgot to pick up the heavy box, it can be obtained by speaking with the guard by the escape hole."
      },
      "chatOptions": []
    },
    {
      "index": 43,
      "indent": 0,
      "section": "Final fight",
      "text": {
        "en": "Talk to King Vargas. You can drop the empty box and diary."
      },
      "chatOptions": []
    },
    {
      "index": 44,
      "indent": 0,
      "section": "Final fight",
      "text": {
        "en": "Quest complete!"
      },
      "chatOptions": []
    }
  ]
