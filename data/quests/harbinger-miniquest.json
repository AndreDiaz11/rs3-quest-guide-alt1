      "section": "Tuai Leit",
      "text": {
        "en": "Speak to Navigator Jemi on Cyclosis (if you have just completed the Eye for an Eye miniquest you may need to relog for the chat option to show up).",
        "es": "Habla con Navigator Jemi en Cyclosis (si acabas de completar la miniquest Eye for an Eye, puede que necesites reconectarte para que aparezca la opción de chat)."
      },
      "chatOptions": [
        "1 Harbinger miniquest.",
        "Accept"
      ]
    },
    {
      "index": 1,
      "indent": 0,
      "section": "Tuai Leit",
      "text": {
        "en": "Travel to Tuai Leit.",
        "es": "Viaja a Tuai Leit."
      },
      "chatOptions": [
        "Any",
        "Any",
        "Any"
      ]
    },
    {
      "index": 2,
      "indent": 0,
      "section": "Tuai Leit",
      "text": {
        "en": "Survive for 2 minutes. The player can simply stand there and wait.",
        "es": "Sobrevive durante 2 minutos. El jugador simplemente puede quedarse quieto esperando."
      },
      "chatOptions": []
    },
    {
      "index": 3,
      "indent": 1,
      "section": "Tuai Leit",
      "text": {
        "en": "Repairing the hull is unnecessary as the damage dealt by the cannonballs is not enough to sink the ship in 2 minutes and Bosun Higgs repairs most of the damages for you.",
        "es": "No es necesario reparar el casco, ya que el daño causado por las balas de cañón no basta para hundir el barco en 2 minutos, y Bosun Higgs repara la mayoría de los daños por ti."
      },
      "chatOptions": []
    },
    {
      "index": 4,
      "indent": 1,
      "section": "Tuai Leit",
      "text": {
        "en": "White rings will indicate where the cannonballs will hit the ship. To reduce the need for food, move your character to avoid the incoming cannonballs.",
        "es": "Unos círculos blancos indicarán dónde impactarán las balas de cañón contra el barco. Para reducir la necesidad de comida, mueve a tu personaje para esquivar las balas entrantes."
      },
      "chatOptions": []
    },
    {
      "index": 5,
      "indent": 0,
      "section": "Tuai Leit",
      "text": {
        "en": "Talk to Navigator Jemi to finish.",
        "es": "Habla con Navigator Jemi para terminar."
      },
      "chatOptions": []
    }
  ]
