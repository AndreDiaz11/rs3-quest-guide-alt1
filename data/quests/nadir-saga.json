  "steps": [
    {
      "index": 0,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Start by finding a damaged device on Daemonheim floors 18-22."
      },
      "chatOptions": [],
      "highlightTerms": [
        "damaged device"
      ]
    },
    {
      "index": 1,
      "indent": 1,
      "section": "Getting started",
      "text": {
        "en": "You might need to talk to Skaldrun to check whether the Nadir saga is already unlocked."
      },
      "chatOptions": []
    },
    {
      "index": 2,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Then start saga with Skaldrun south-west of the Daemonheim entrance."
      },
      "chatOptions": []
    },
    {
      "index": 3,
      "indent": 0,
      "section": "The Ritual Site",
      "text": {
        "en": "Wait approximately one minute for Zemouregal and Lucien to finish their conversation."
      },
      "chatOptions": []
    },
    {
      "index": 4,
      "indent": 0,
      "section": "The Ritual Site",
      "text": {
        "en": "Finish the dialogue and cutscene then continue north to interrogate the merchant."
      },
      "chatOptions": []
    },
    {
      "index": 5,
      "indent": 0,
      "section": "The Ritual Site",
      "text": {
        "en": "Hunt for 3 memories (having sound turned on helps a lot here)."
      },
      "chatOptions": []
    },
    {
      "index": 6,
      "indent": 1,
      "section": "The Ritual Site",
      "text": {
        "en": "Move your mouse around until the orange circle rapidly pulses THREE times per second on a location, and click, as this is a correct spot. There are three speeds--you want to click at the fastest, highest-pitched ping. Repeat until all three memories are recovered."
      },
      "chatOptions": []
    },
    {
      "index": 7,
      "indent": 1,
      "section": "The Ritual Site",
      "text": {
        "en": "If only half the memory is recovered, you did not do this step correctly and as a result an unabridged tome will not be awarded, you can lobby to restart the saga."
      },
      "chatOptions": []
    },
    {
      "index": 8,
      "indent": 1,
      "section": "The Ritual Site",
      "text": {
        "en": "A pinging sound will play if game sounds are turned on: a slow hum (level 1), a moderately fast ping (level 2, indicating you are close to the correct position), and a fast, high-frequency ping that plays ~2 times a second. This is the correct location for full memory retrieval."
      },
      "chatOptions": [],
      "boldTerms": [
        "This"
      ]
    },
    {
      "index": 9,
      "indent": 1,
      "section": "The Ritual Site",
      "text": {
        "en": "The correct location does not always correspond to the centre of a memory you can see. It can also be an empty space."
      },
      "chatOptions": []
    },
    {
      "index": 10,
      "indent": 1,
      "section": "The Ritual Site",
      "text": {
        "en": "Note: On mobile, there is a bug, read the full article to find out how to deal with this."
      },
      "chatOptions": []
    },
    {
      "index": 11,
      "indent": 0,
      "section": "The Ritual Site",
      "text": {
        "en": "Continue north and climb down the dungeon entrance."
      },
      "chatOptions": []
    },
    {
      "index": 12,
      "indent": 0,
      "section": "Frozen floors",
      "text": {
        "en": "Continue east through the door."
      },
      "chatOptions": []
    },
    {
      "index": 13,
      "indent": 0,
      "section": "Frozen floors",
      "text": {
        "en": "Attempt to pass the captain."
      },
      "chatOptions": []
    },
    {
      "index": 14,
      "indent": 0,
      "section": "Frozen floors",
      "text": {
        "en": "Probe 3 memories again."
      },
      "chatOptions": []
    },
    {
      "index": 15,
      "indent": 0,
      "section": "Frozen floors",
      "text": {
        "en": "Continue through the east door, then the south door."
      },
      "chatOptions": []
    },
    {
      "index": 16,
      "indent": 1,
      "section": "Frozen floors",
      "text": {
        "en": "You will enter a room full of guards. After some dialogues, enter the south room."
      },
      "chatOptions": []
    },
    {
      "index": 17,
      "indent": 0,
      "section": "Furnished floors",
      "text": {
        "en": "Head north through the door and about half way into the room to get a message then leave the same way."
      },
      "chatOptions": []
    },
    {
      "index": 18,
      "indent": 0,
      "section": "Furnished floors",
      "text": {
        "en": "Continue south through the door and finish dialogue with the soldier."
      },
      "chatOptions": []
    },
    {
      "index": 19,
      "indent": 1,
      "section": "Furnished floors",
      "text": {
        "en": "Select \"Got something to get off your chest, soldier? Be my guest.\""
      },
      "chatOptions": []
    },
    {
      "index": 20,
      "indent": 0,
      "section": "Furnished floors",
      "text": {
        "en": "Continue south and then west and finish dialogue with the mage."
      },
      "chatOptions": []
    },
    {
      "index": 21,
      "indent": 1,
      "section": "Furnished floors",
      "text": {
        "en": "Select \"Ask me later, Druf. I have no time for you right now.\""
      },
      "chatOptions": []
    },
    {
      "index": 22,
      "indent": 0,
      "section": "Furnished floors",
      "text": {
        "en": "Continue south through the door and finish dialogue with the soldier."
      },
      "chatOptions": []
    },
    {
      "index": 23,
      "indent": 1,
      "section": "Furnished floors",
      "text": {
        "en": "Select \"Tell them to wait there, and no practice until I return.\""
      },
      "chatOptions": []
    },
    {
      "index": 24,
      "indent": 0,
      "section": "Furnished floors",
      "text": {
        "en": "Continue east."
      },
      "chatOptions": []
    },
    {
      "index": 25,
      "indent": 1,
      "section": "Furnished floors",
      "text": {
        "en": "If you enter combat in this room then you have failed the dialogue options above, restart from checkpoint."
      },
      "chatOptions": []
    },
    {
      "index": 26,
      "indent": 0,
      "section": "Furnished floors",
      "text": {
        "en": "Continue east, south, and south."
      },
      "chatOptions": []
    },
    {
      "index": 27,
      "indent": 0,
      "section": "Furnished floors",
      "text": {
        "en": "Probe 3 memories again."
      },
      "chatOptions": []
    },
    {
      "index": 28,
      "indent": 0,
      "section": "Furnished floors",
      "text": {
        "en": "Kill the necrolord and continue south."
      },
      "chatOptions": []
    },
    {
      "index": 29,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Head east and east again. Walk into the centre of the room with bodies. Continue west to view a cutscene."
      },
      "chatOptions": []
    },
    {
      "index": 30,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Exit the room and continue south, then finish the dialogue with the necrolord."
      },
      "chatOptions": []
    },
    {
      "index": 31,
      "indent": 1,
      "section": "Occult floors",
      "text": {
        "en": "Select \"Cut off their hands.\""
      },
      "chatOptions": []
    },
    {
      "index": 32,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Continue south, west and finish dialogue with the necrolord again."
      },
      "chatOptions": []
    },
    {
      "index": 33,
      "indent": 1,
      "section": "Occult floors",
      "text": {
        "en": "Select \"Kill him, or I will kill you.\""
      },
      "chatOptions": []
    },
    {
      "index": 34,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Continue west and move into the room. You will move toward both portals and drain their power."
      },
      "chatOptions": []
    },
    {
      "index": 35,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Continue south and finish the dialogue with the necrolord."
      },
      "chatOptions": []
    },
    {
      "index": 36,
      "indent": 1,
      "section": "Occult floors",
      "text": {
        "en": "Select \"His body is on the floor above. Fetch it yourself, I am busy.\""
      },
      "chatOptions": []
    },
    {
      "index": 37,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Continue east."
      },
      "chatOptions": []
    },
    {
      "index": 38,
      "indent": 1,
      "section": "Occult floors",
      "text": {
        "en": "If you enter combat in this room then you have failed the dialogue options above, restart from checkpoint."
      },
      "chatOptions": []
    },
    {
      "index": 39,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Continue east and drain BOTH portals."
      },
      "chatOptions": []
    },
    {
      "index": 40,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Continue south, then east."
      },
      "chatOptions": []
    },
    {
      "index": 41,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Kill the Hooved Mage and then drain the portal."
      },
      "chatOptions": []
    },
    {
      "index": 42,
      "indent": 0,
      "section": "Occult floors",
      "text": {
        "en": "Continue east, kill the four soldiers and two rangers, and then continue east."
      },
      "chatOptions": []
    },
    {
      "index": 43,
      "isSectionNote": true,
      "section": "Warped floors",
      "needed": {
        "text": {
          "en": "Active standard spellbook"
        },
        "highlightTerms": [
          "standard spellbook"
        ]
      }
    },
    {
      "index": 44,
      "indent": 0,
      "section": "Warped floors",
      "text": {
        "en": "Drain the power from the portal, then head south and kill the two rangers and three soldiers."
      },
      "chatOptions": []
    },
    {
      "index": 45,
      "indent": 0,
      "section": "Warped floors",
      "text": {
        "en": "Head east, drain the north west portal and unlock the silver shield door."
      },
      "chatOptions": []
    },
    {
      "index": 46,
      "indent": 0,
      "section": "Warped floors",
      "text": {
        "en": "Continue east and kill the three soldiers, one ranger, and one mage. Drain the portal power."
      },
      "chatOptions": []
    },
    {
      "index": 47,
      "indent": 0,
      "section": "Warped floors",
      "text": {
        "en": "Continue south, drain the portal."
      },
      "chatOptions": []
    },
    {
      "index": 48,
      "indent": 0,
      "section": "Warped floors",
      "text": {
        "en": "Continue south, kill the two hellhounds and two soldiers, drain the portal, then unlock the green pentagon door."
      },
      "chatOptions": []
    },
    {
      "index": 49,
      "indent": 0,
      "section": "Warped floors",
      "text": {
        "en": "Continue west and kill the three soldiers, one ranger, and one mage. Drain BOTH portals and continue west."
      },
      "chatOptions": []
    },
    {
      "index": 50,
      "indent": 1,
      "section": "Warped floors",
      "text": {
        "en": "Your adrenaline will stay constant and will no longer drain. Your adrenaline may drain during the following cutscene, but full completion is still awarded."
      },
      "chatOptions": []
    },
    {
      "index": 51,
      "indent": 0,
      "section": "Warped floors",
      "text": {
        "en": "Continue east, continue dialogue and investigate the ritual marker."
      },
      "chatOptions": [
        "Any"
      ]
    },
    {
      "index": 52,
      "indent": 0,
      "section": "Warped floors",
      "text": {
        "en": "Talk to Bilrach."
      },
      "chatOptions": [
        "5 Why is the Ritual Marker here?",
        "4 What is this place? What is it for?",
        "3 How long have you been here?",
        "2 Tell me of the portals and their power.",
        "1 How did you know I was talking to Lucien?",
        "5 What happens now?",
        "Any"
      ]
