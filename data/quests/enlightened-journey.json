  "steps": [
    {
      "index": 0,
      "isSectionNote": true,
      "section": "Getting started",
      "needed": {
        "text": {
          "en": "3 papyrus, 1 ball of wool, 1 sack of potatoes, and 1 white candle"
        },
        "highlightTerms": [
          "sack of potatoes",
          "papyrus",
          "ball of wool",
          "white candle"
        ]
      }
    },
    {
      "index": 1,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "If you don't have a sack of potatoes yet, fill an empty sack with potatoes in the farm north-east of Auguste. Pick the 6 that are there, wait for more to respawn, then pick 4 more. Click fill on the sack.",
        "es": "Si aún no tienes un saco de patatas, llena un saco vacío con patatas en la granja al noreste de Auguste. Recoge las 6 que hay, espera a que reaparezcan más y recoge 4 más. Haz clic en \"llenar\" en el saco."
      },
      "chatOptions": []
    },
    {
      "index": 2,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to Auguste on Entrana, north of the Herblore shop.",
        "es": "Habla con Auguste en Entrana, al norte de la tienda de Herboristería."
      },
      "chatOptions": [
        "Accept"
      ],
      "highlightTerms": [
        "Auguste",
        "Entrana"
      ]
    },
    {
      "index": 3,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to him again.",
        "es": "Habla con él de nuevo."
      },
      "chatOptions": [
        "1 Umm, yes. What's your point?"
      ]
    },
    {
      "index": 4,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to him for a third time.",
        "es": "Habla con él por tercera vez."
      },
      "chatOptions": [
        "1 Yes."
      ]
    },
    {
      "index": 5,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Use a papyrus with a ball of wool.",
        "es": "Usa un papiro con una bola de lana."
      },
      "chatOptions": []
    },
    {
      "index": 6,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Use an unlit candle on the balloon structure.",
        "es": "Usa una vela apagada en la estructura del globo."
      },
      "chatOptions": [],
      "highlightTerms": [
        "balloon structure"
      ]
    },
    {
      "index": 7,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to Auguste to launch the origami balloon. (Do not use the balloon's Launch option or you will need to make another.)",
        "es": "Habla con Auguste para lanzar el globo de origami. (No uses la opción \"Lanzar\" del globo o tendrás que hacer otro.)"
      },
      "chatOptions": [],
      "boldTerms": [
        "Do not"
      ]
    },
    {
      "index": 8,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Talk to Auguste again with two papyrus and a sack of potatoes.",
        "es": "Habla con Auguste de nuevo con dos papiros y un saco de patatas."
      },
      "chatOptions": [
        "1 Yes, I have them here."
      ]
    },
    {
      "index": 9,
      "indent": 0,
      "section": "Getting started",
      "text": {
        "en": "Speak with Auguste once more and he will give you Auguste's sapling and basket of Apples.",
        "es": "Habla con Auguste una vez más y te dará el brote de Auguste y una cesta de manzanas."
      },
      "chatOptions": [],
      "highlightTerms": [
        "Auguste's sapling",
        "Apples"
      ]
    },
    {
      "index": 10,
      "isSectionNote": true,
      "section": "The Big Balloon",
      "needed": {
        "text": {
          "en": "1 yellow dye, 1 red dye, 10 silk, 1 bowl, and 8 sacks. (Keep the 2 papyrus and 1 sack of potatoes in your inventory if not used in the last step.) Note: Noted items do not work"
        },
        "highlightTerms": [
          "sack of potatoes",
          "yellow dye",
          "red dye",
          "silk",
          "bowl",
          "sacks",
          "papyrus"
        ]
      }
    },
    {
      "index": 11,
      "indent": 0,
      "section": "The Big Balloon",
      "text": {
        "en": "Fill 8 sacks with sand at the sandpit just south-east of Auguste",
        "es": "Llena 8 sacos con arena en el arenal justo al sureste de Auguste."
      },
      "chatOptions": [],
      "highlightTerms": [
        "sandpit"
      ]
    },
    {
      "index": 12,
      "indent": 0,
      "section": "The Big Balloon",
      "text": {
        "en": "Give Auguste the items listed above.",
        "es": "Dale a Auguste los objetos indicados arriba."
      },
      "chatOptions": [
        "1 Yes, I want to give you some items.",
        "1 Dye.",
        "1 Sandbags.",
        "1 Silk.",
        "1 Bowl.",
        "2 Fine thanks."
      ]
    },
    {
      "index": 13,
      "indent": 0,
      "section": "The Big Balloon",
      "text": {
        "en": "Bank for the willow branches. Go back and use the branches on the balloon frame on the platform.",
        "es": "Ve al banco a por las ramas de sauce. Vuelve y usa las ramas en la estructura del globo en la plataforma."
      },
      "chatOptions": []
    },
    {
      "index": 14,
      "indent": 0,
      "section": "The Big Balloon",
      "text": {
        "en": "Obtain at least 10 normal logs from nearby trees.",
        "es": "Consigue al menos 10 troncos normales de los árboles cercanos."
      },
      "chatOptions": [],
      "highlightTerms": [
        "logs"
      ]
    },
    {
      "index": 15,
      "indent": 0,
      "section": "In Flight",
      "text": {
        "en": "Talk to Auguste to begin the flight.",
        "es": "Habla con Auguste para comenzar el vuelo."
      },
      "chatOptions": [
        "2 Okay."
      ]
    },
    {
      "index": 16,
      "indent": 1,
      "section": "In Flight",
      "text": {
        "en": "You must take all items from your BoB and dismiss it at this point to begin the flight.",
        "es": "Debes sacar todos los objetos de tu BoB y despedirlo antes de comenzar el vuelo."
      },
      "chatOptions": []
    },
    {
      "index": 17,
      "indent": 0,
      "section": "In Flight",
      "text": {
        "en": "In the event the client doesn't load the interface properly, you will need to restart, requiring another 10 logs.",
        "es": "Si el cliente no carga bien la interfaz, tendrás que reiniciar, lo que requerirá otros 10 troncos."
      },
      "chatOptions": []
