    {
      "index": 1,
      "indent": 0,
      "section": "Learning about Halloween plans",
      "text": {
        "en": "Talk to Death, Famine, Frank, Pestilence, or War in the Harvest Hollow.",
        "es": "Habla con Death, Famine, Frank, Pestilence o War en Harvest Hollow."
      },
      "chatOptions": [
        "Accept"
      ],
      "highlightTerms": [
        "Frank",
        "Death",
        "Famine",
        "Pestilence",
        "War",
        "Harvest Hollow"
      ]
    },
    {
      "index": 2,
      "indent": 0,
      "section": "Learning about Halloween plans",
      "text": {
        "en": "Wear or enable as a cosmetic override four components from the above table. If wearing an item, you must not override its slot with a cosmetic override.",
        "es": "Viste o activa como apariencia cuatro componentes de la tabla anterior. Si llevas puesto un objeto, no debes sustituir su ranura con una apariencia."
      },
      "chatOptions": [],
      "highlightTerms": [
        "item",
        "cosmetic override"
      ]
    },
    {
      "index": 3,
      "indent": 0,
      "section": "Learning about Halloween plans",
      "text": {
        "en": "Talk again to one of Death, Famine, Frank, Pestilence, or War. (This choice will affect the quest's rewards.)",
        "es": "Vuelve a hablar con Death, Famine, Frank, Pestilence o War. (Esta elección afectará a las recompensas de la misión.)"
      },
      "chatOptions": [
        "1 Yes.",
        "1 Can you check my outfit?"
      ]
    },
