    {
      "index": 0,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Speak to Doric in his hut north of Falador.",
        "es": "Habla con Doric en su cabaña al norte de Falador."
      },
      "chatOptions": [
        "1 Do you have any more Smithing tasks for me?",
        "Accept"
      ],
      "highlightTerms": [
        "Doric",
        "Falador"
      ]
    },
    {
      "index": 1,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Smith two steel chainbodies.",
        "es": "Forja dos cotas de malla de acero."
      },
      "chatOptions": [],
      "highlightTerms": [
        "steel chainbodies"
      ]
    },
    {
      "index": 2,
      "indent": 1,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Make sure you are smithing chainbodies, not platebodies.",
        "es": "Asegúrate de forjar cotas de malla, no petos."
      },
      "chatOptions": [],
      "highlightTerms": [
        "platebodies"
      ]
    },
    {
      "index": 3,
      "indent": 1,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Purchasing chainbodies from the Grand Exchange will not complete the task.",
        "es": "Comprar cotas de malla en el Grand Exchange no completará la tarea."
      },
      "chatOptions": [],
      "highlightTerms": [
        "Grand Exchange"
      ]
    },
    {
      "index": 4,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Deliver the chainbodies to Commander Denulth, north-east of Burthorpe lodestone.",
        "es": "Entrega las cotas de malla a Commander Denulth, al noreste de la piedra de viaje de Burthorpe."
      },
      "chatOptions": [
        "1 Ask about Doric's Tasks"
      ],
      "highlightTerms": [
        "Commander Denulth",
        "Burthorpe lodestone"
      ]
    },
    {
      "index": 5,
      "indent": 1,
      "section": "Attack of the Trolls",
      "text": {
        "en": "There are breaks in the dialogue. Make sure the conversation is completed.",
        "es": "Hay pausas en el diálogo. Asegúrate de completar la conversación."
      },
      "chatOptions": []
    },
    {
      "index": 6,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Return to Doric and speak to him.",
        "es": "Vuelve con Doric y habla con él."
      },
      "chatOptions": [
        "1 Do you have any more Smithing tasks for me?"
      ]
    },
    {
      "index": 7,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Have 2 unnoted bronze bars in your inventory.",
        "es": "Ten 2 barras de bronce sin marcar en tu inventario."
      },
      "chatOptions": [],
      "highlightTerms": [
        "bronze bar"
      ]
    },
    {
      "index": 8,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Use the anvil in the same room as Doric to make the cannon repair part.",
        "es": "Usa el yunque de la misma sala que Doric para fabricar la pieza de reparación del cañón."
      },
      "chatOptions": []
    },
    {
      "index": 9,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Return to Burthorpe and head north to the castle. Outside the castle, climb the ladder west of the entrance to reach the roof.",
        "es": "Vuelve a Burthorpe y dirígete al norte hacia el castillo. Fuera del castillo, sube por la escalera al oeste de la entrada para llegar al tejado."
      },
      "chatOptions": [],
      "highlightTerms": [
        "castle"
      ]
    },
    {
      "index": 10,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Repair the middle broken cannon to the north.",
        "es": "Repara el cañón roto del centro, al norte."
      },
      "chatOptions": []
    },
    {
      "index": 11,
      "indent": 0,
      "section": "Attack of the Trolls",
      "text": {
        "en": "Return to Commander Denulth.",
        "es": "Vuelve con Commander Denulth."
      },
      "chatOptions": [
        "1 I've fixed the cannon."
      ]
