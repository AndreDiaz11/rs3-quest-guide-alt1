    {
      "index": 5,
      "indent": 0,
      "section": "Setting up the quest",
      "text": {
        "en": "Go into the wheat field in Draynor Village south east of the lodestone and pick up three spooky scarecrows.",
        "es": "Ve al campo de trigo de Draynor Village, al sureste de la piedra de viaje, y coge tres espantapájaros espeluznantes."
      },
      "chatOptions": [],
      "highlightTerms": [
        "Draynor Village",
        "spooky scarecrow"
      ]
    },
    {
      "index": 6,
      "indent": 0,
      "section": "Setting up the quest",
      "text": {
        "en": "Place the scarecrows at the markers north-west of the lodestone, just behind the entrance to Death's Office by the trees. Look for the lit candles near wooden markers. Click on the wooden markers to plant the scarecrows.",
        "es": "Coloca los espantapájaros en las marcas al noroeste de la piedra de viaje, justo detrás de la entrada al despacho de Death, junto a los árboles. Busca las velas encendidas cerca de las marcas de madera. Haz clic en las marcas de madera para plantar los espantapájaros."
      },
      "chatOptions": [],
      "highlightTerms": [
        "markers",
        "Death's Office"
      ]
    },
    {
      "index": 7,
      "indent": 0,
      "section": "Setting up the quest",
      "text": {
        "en": "Go back and talk to Closure again.",
        "es": "Vuelve y habla de nuevo con Closure."
      },
      "chatOptions": []
    },
    {
      "index": 8,
      "indent": 0,
      "section": "Setting up the quest",
      "text": {
        "en": "Hide the confiscated sword at the marker just west of the scarecrow markers.",
        "es": "Esconde la espada confiscada en la marca situada justo al oeste de las marcas de los espantapájaros."
      },
      "chatOptions": [],
      "highlightTerms": [
        "confiscated sword"
      ]
    },
    {
      "index": 9,
      "indent": 0,
      "section": "Setting up the quest",
      "text": {
        "en": "Go back and talk to Closure again.",
        "es": "Vuelve y habla de nuevo con Closure."
      },
      "chatOptions": []
    },
    {
      "index": 10,
      "indent": 0,
      "section": "Setting up the quest",
      "text": {
        "en": "Go to the Dancing Donkey Inn (south east Varrock) and talk to Relomia twice.",
        "es": "Ve al Dancing Donkey Inn (al sureste de Varrock) y habla con Relomia dos veces."
      },
      "chatOptions": [
        "Any"
      ],
      "highlightTerms": [
